NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_value_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_value_here
NEXT_PUBLIC_COLLECTION_SUBJECTS=your_value_here
NEXT_PUBLIC_COLLECTION_QUESTIONS=your_value_here
NEXT_PUBLIC_POSTHOG_KEY=your_value_here
NEXT_PUBLIC_POSTHOG_HOST=your_value_here

# Razorpay (server-side only — never prefix with NEXT_PUBLIC_)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Admin email gate
ADMIN_EMAIL=your_admin_email_here
